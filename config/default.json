{
    "version": "1.0",
    "dealer_id": "Edge001",
    "mode": "Binary",
    "jpeg_quality": 85,
    "http_file_server_port": 8089,
    "ai_engine_http_url": "https://127.0.0.1:8000",
    "api1a": {
        "transport": "ipc",
        "endpoint_local": "ipc:///tmp/ai_vision_dealer_detection",
        "endpoint_remote": "tcp://localhost:5555",
        "identity": "ai_vision_server_dealer",
        "sndhwm": 10,
        "rcvhwm": 10,
        "poll_timeout_ms": 100
    },
    "api1b": {
        "host": "0.0.0.0",
        "port": 8445,
        "cert_path": "certs/server.crt",
        "key_path": "certs/server.key",
        "worker_threads": 4
    },
    "api2a": {
        "transport": "ipc",
        "channels": {
            "image": "ipc:///tmp/sc_pub_stereo_image",
            "depth_map": "ipc:///tmp/sc_pub_depth_map",
            "point_cloud": "ipc:///tmp/sc_pub_point_cloud",
            "imu": "ipc:///tmp/sc_pub_imu",
            "magnetometer": "ipc:///tmp/sc_pub_magnetometer",
            "barometer": "ipc:///tmp/sc_pub_barometer"
        },
        "default_channel": "image",
        "rcvhwm": 10,
        "result_endpoint": "ipc:///tmp/ai_vision_dealer_result"
    },
    "api2b": {
        "host": "0.0.0.0",
        "port": 8446,
        "cert_path": "certs/server.crt",
        "key_path": "certs/server.key",
        "worker_threads": 4
    },
    "log_level": "info"
}

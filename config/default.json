{
    "version": "1.0",
    "dealer_id": "Edge001",
    "api1a": {
        "transport": "ipc",
        "endpoint_local": "ipc:///tmp/ai_vision_dealer_detection",
        "endpoint_remote": "tcp://localhost:5555",
        "identity": "ai_vision_server_dealer",
        "sndhwm": 10,
        "rcvhwm": 10,
        "poll_timeout_ms": 100
    },
    "api1b": {
        "host": "0.0.0.0",
        "port": 8445,
        "cert_path": "certs/server.crt",
        "key_path": "certs/server.key",
        "worker_threads": 4
    },
    "api2a": {
        "transport": "ipc",
        "channels": {
            "image": "ipc:///tmp/sc_pub_stereo_image",
            "stereo_image": "ipc:///tmp/sc_pub_stereo_image"
        },
        "default_channel": "image",
        "stereo_mode": true,
        "rcvhwm": 10
    },
    "api2b": {
        "transport": "ipc",
        "endpoint_local": "ipc:///tmp/ai_vision_dealer_result",
        "endpoint_remote": "tcp://*:5556",
        "sndhwm": 10
    },
    "log_level": "info"
}